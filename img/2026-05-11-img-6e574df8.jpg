ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":792,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":797,"length":24,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":821,"length":5,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":826,"length":23,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"}],"backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4293982975,"raisedBackground":4293982975,"additiveBackground":558211273,"textPrimary":4278855734,"textSecondary":4282015342,"invertedBackground":4279856015,"overlayBackground":3423217718},"darkThemeColorPalette":{"baseBackground":4278326300,"raisedBackground":4278855734,"additiveBackground":725983433,"textPrimary":4292932346,"textSecondary":4289515229,"invertedBackground":4286366947,"overlayBackground":3423217718},"colorSampledDescriptionBodyText":{"content":"Boris Cherny, creator of Claude Code at Anthropic, joins Sequoia partner Lauren Reeder at AI Ascent 2026 to talk about where coding goes from here. He explains why he hasn't written a line of code in 2026, why he now ships dozens of PRs a day from his phone, and why he believes coding is effectively solved — at least for the code he writes. Also: why loops are the future, why he thinks Claude Code itself may be 100 lines of code a year from now, and why the invention of the printing press is the right analogy for what's about to happen to software.\n\n00:00 Introduction\n00:55 Claude Code Crowd Check\n02:39 Origin Story of Claude Code\n03:35 From Typeahead to Agents\n05:07 Is Coding Solved\n06:50 Boris Personal Workflow\n08:51 Future Teams and Generalists\n10:26 SaaS Apocalypse Predictions\n12:57 Audience Q\u0026A Deep Dive\n23:35 Closing and Whats Next","commandRuns":[{"startIndex":556,"length":5,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBQQ040EGAciEwjgvOaJx7CUAxVBbfUHHeCjFCPKAQTsgh