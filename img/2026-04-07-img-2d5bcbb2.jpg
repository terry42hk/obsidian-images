toidRenderer":{"value":{"simpleText":"2023年"},"label":{"simpleText":"12月21日"},"accessibilityText":"2023年12月21日","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4293980415,"raisedBackground":4293980415,"additiveBackground":557990860,"textPrimary":4278519354,"textSecondary":4280230026,"invertedBackground":4279835280,"overlayBackground":3422881338},"darkThemeColorPalette":{"baseBackground":4278256157,"raisedBackground":4278519354,"additiveBackground":725763020,"textPrimary":4292796156,"textSecondary":4288454125,"invertedBackground":4286414563,"overlayBackground":3422881338},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CBQQ040EGAYiEwjg-r-v4tmTAxUXRDgFHYAWNBPKAQRIyZNc","commandMetadata":{"webCommandMetadata":{"url":"/@the_visibility_goddess","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCuLl406sTHMqDcn3_sSFEhQ","canonicalBaseUrl":"/@the_visibility_goddess"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/V51mykYw5WOMIYjk_dOS_rOzLN1Xrtv7nA4msyBDeU17uhcys9z47yYkDBBmEpREgSmJEsWM=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"顯示完整資訊"}},"simpleText":"...更多內容"},"showLessText":{"simpleText":"只顯示部分資訊"},"attributedDescriptionBodyText":{"content":"So, you’ve discovered you’re a Projector in Human Design—meant to wait for invitations in a world that worships hustle and initiation. What now?\n\nThis video is your guide to thriving as a Projector in business and leadership. You’ll learn how to step into your power, honour your energetic role, and orchestrate the invitations that lead to real success.\n\n✨ In this video:\n\nWhy the traditional leadership model doesn’t work for Projectors\nWhat “waiting for the invitation” really looks like in business\nHow to lead without initiating or pushing\nPractical ways to build visibility and magnetise aligned opportunities\nReframing success and power through the Projector lens\nCreating an environment that supports recognition\n\n✨ Join The Invitation – my online course for Projectors who are ready to lead in their true energetic power:\n👉 https://www.abigailrebecca.com/the-in...\n\n🎁 PROJECTORS: Get your free guide to the 3 blind spots blocking invitations right now:\n👉 https://www.abigailrebecca.com/free-gift\n\n🔮 Order the Human Design Visibility Guide and align your business strategy to your chart:\n👉 https://www.abigailrebecca.com/visibi...\n\n📸 Follow along on Instagram for more updates and resources:\n👉   / the_visibility_goddess  \n\n#ProjectorBusinessTips #HumanDesignProjector #ProjectorStrategy #WaitingForTheInvitation #AbigailRebecca #HumanDesignForBusiness #AuthenticLeadership #ICONICLeadership #OrchestrateTheInvitation #ProjectorSuccess","commandRuns":[{"startIndex":834,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBQQ040EGAYiEwjg-r-v4tmTAxUXRDgFHYAWNBNI8I_kqLTH29jQAcoBBEjJk1w=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqblc4bEVWM1M1OUJMYUxnMmZsVDZTaGx1UmVvQXxBQ3Jtc0ttbGlidnp0YnhQQTJCOWR5M1NTdUpGU1hDMjRPdUtLUGk1TGpMMXBYbkxOdEJ3U0pJT28zYzdvcVRqUEVhdk1QUDhCQjdGa2llbXAwMmtyTTVUakZmZ2FvRURCcUExdjV0RHJrOWFBVXprdTZOeFo5OA\u0026q=https%3A%2F%2Fwww.abigailrebecca.com%2Fthe-invitation\u0026v=0LFuO0UZB_A","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqblc4bEVWM1M1OUJMYUxnMmZsVDZTaGx1UmVvQXxBQ3Jtc0ttbGlidnp0YnhQQTJCOWR5M1NTdUpGU1hDMjRPdUtLUGk1TGpMMXBYbkxOdEJ3U0pJT28zYzdvcVRqUEVhdk1QUDhCQjdGa2llbXAwMmtyTTVUakZmZ2FvRURCcUExdjV0RHJrOWFBVXprdTZOeFo5OA\u0026q=https%3A%2F%2Fwww.abigailrebecca.com%2Fthe-invitation\u0026v=0LFuO0UZB_A","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startI