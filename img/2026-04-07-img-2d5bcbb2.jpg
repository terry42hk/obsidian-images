LFuO0UZB_A"}]}}}}},"storyboards":{"playerStoryboardSpecRenderer":{"spec":"https://i.ytimg.com/sb/0LFuO0UZB_A/storyboard3_L$L/$N.jpg?sqp=-oaymwGhAUg48quKqQOYAYgBAZUBAAAEQpgBMqABPKgBBLIBQBANDBAVHyYtDg4PEhcrLCkPDhAVHyoyKQ8RFBgmPTgtERQeKjFLRzYVHCkuOUdNPyUuNz1HUlFFM0BCQ0xERkO6AUARERUjRENDQxETFi9DQ0NDFRYpQ0NDQ0MjL0NDQ0NDQ0RDQ0NDQ0JCQ0NDQ0NCQkJDQ0NDQkJCQkNDQ0JCQkJCovOX_wMGCKvRkawG|48#27#100#10#10#0#default#rs$AOn4CLBUDj0ShCaZ9jGaU7Mx7DSN9LJq-A|80#45#135#10#10#10000#M$M#rs$AOn4CLACmHYNZyUAg2YDQD4r3S8AtavjRA|160#90#135#5#5#10000#M$M#rs$AOn4CLDtRhR4IYLJy1Eo_fz3k07NN-8oHg|320#180#135#3#3#10000#M$M#rs$AOn4CLCK16VrV8UrjQobIhjl5w90xxhZdw","recommendedLevel":3,"fineScrubbingRecommendedLevel":2,"highResolutionRecommendedLevel":3}},"microformat":{"playerMicroformatRenderer":{"thumbnail":{"thumbnails":[{"url":"https://i.ytimg.com/vi/0LFuO0UZB_A/maxresdefault.jpg","width":1280,"height":720}]},"embed":{"iframeUrl":"https://www.youtube.com/embed/0LFuO0UZB_A","width":1280,"height":720},"title":{"simpleText":"SO YOU'RE A PROJECTOR... NOW WHAT? | HUMAN DESIGN STRATEGY FOR BUSINESS \u0026 LEADERSHIP"},"description":{"simpleText":"So, you’ve discovered you’re a Projector in Human Design—meant to wait for invitations in a world that worships hustle and initiation. What now?\n\nThis video is your guide to thriving as a Projector in business and leadership. You’ll learn how to step into your power, honour your energetic role, and orchestrate the invitations that lead to real success.\n\n✨ In this video:\n\nWhy the traditional leadership model doesn’t work for Projectors\nWhat “waiting for the invitation” really looks like in business\nHow to lead without initiating or pushing\nPractical ways to build visibility and magnetise aligned opportunities\nReframing success and power through the Projector lens\nCreating an environment that supports recognition\n\n✨ Join The Invitation – my online course for Projectors who are ready to lead in their true energetic power:\n👉 https://www.abigailrebecca.com/the-invitation\n\n🎁 PROJECTORS: Get your free guide to the 3 blind spots blocking invitations right now:\n👉 https://www.abigailrebecca.com/free-gift\n\n🔮 Order the Human Design Visibility Guide and align your business strategy to your chart:\n👉 https://www.abigailrebecca.com/visibility-guide\n\n📸 Follow along on Instagram for more updates and resources:\n👉 https://www.instagram.com/the_visibility_goddess\n\n#ProjectorBusinessTips #HumanDesignProjector #ProjectorStrategy #WaitingForTheInvitation #AbigailRebecca #HumanDesignForBusiness #AuthenticLeadership #ICONICLeadership #OrchestrateTheInvitation #ProjectorSuccess"},"lengthSeconds":"1332","ownerProfileUrl":"http://www.youtube.com/@the_visibility_goddess","externalChannelId":"UCuLl406sTHMqDcn3_sSFEhQ","isFamilySafe":true,"availableCountries":["AD","AE","AF","AG","AI","AL","AM","AO","AQ","AR","AS","AT","AU","AW","AX","AZ","BA","BB","BD","BE","BF","BG","BH","BI","BJ","BL","BM","BN","BO","BQ","BR","BS","BT","BV","BW","BY","BZ","CA","CC","CD","CF","CG","CH","CI","CK","CL","CM","CN","CO","CR","CU","CV","CW","CX","CY","CZ","DE","DJ","DK","DM","DO","DZ","EC","EE","EG","EH","ER","ES","ET","FI","FJ","FK","FM","FO","FR","GA","GB","GD","GE","GF","GG","GH","GI","GL","GM","GN","GP","GQ","GR","GS","GT","GU","GW","GY","HK","HM","HN","HR","HT","HU","ID","IE","IL","IM","IN","IO","IQ","IR","IS","IT","JE","JM","JO","JP","KE","KG","KH","KI","KM","KN","KP","KR","KW","KY","KZ","LA","LB","LC","LI","LK","LR","LS","LT","LU","LV","LY","MA","MC","MD","ME","MF","MG","MH","MK","ML","MM","MN","MO","MP","MQ","MR","MS","MT","MU","MV","MW","MX","MY","MZ","NA","NC","NE","NF","NG","NI","NL","NO","NP","NR","NU","NZ","OM","PA","PE","PF","PG","PH","PK","PL","PM","PN","PR","PS","PT","PW","PY","QA","RE","RO","RS","RU","RW","SA","SB","SC","SD","SE","SG","SH","SI","SJ","SK","SL","SM","SN","SO","SR","SS","ST","SV","SX","SY","SZ","TC","TD","TF","TG","TH","TJ","TK","TL","TM","TN","TO","TR","TT","TV","TW","TZ","UA","UG","UM","US","UY","UZ","VA","VC","VE","VG",