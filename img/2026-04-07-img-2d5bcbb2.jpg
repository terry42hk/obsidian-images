gailrebecca.com/expansion-circle\n\n\n"},"callToAction":{"simpleText":"瀏覽頻道"},"dismiss":{"simpleText":"取消"},"endpoint":{"clickTrackingParams":"CAYQ-N4BGAAiEwjf67-v4tmTAxWJcPUFHX0iMP0yDGl2LWVuZHNjcmVlbkjwj-SotMfb2NABygEESMmTXA==","commandMetadata":{"webCommandMetadata":{"url":"/channel/UCuLl406sTHMqDcn3_sSFEhQ","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCuLl406sTHMqDcn3_sSFEhQ"}},"hovercardButton":{"subscribeButtonRenderer":{"buttonText":{"runs":[{"text":"訂閱"}]},"subscribed":false,"enabled":true,"type":"FREE","channelId":"UCuLl406sTHMqDcn3_sSFEhQ","showPreferences":false,"subscribedButtonText":{"runs":[{"text":"已訂閱"}]},"unsubscribedButtonText":{"runs":[{"text":"訂閱"}]},"trackingParams":"CAcQmysiEwjf67-v4tmTAxWJcPUFHX0iMP0yDGl2LWVuZHNjcmVlbg==","unsubscribeButtonText":{"runs":[{"text":"取消訂閱"}]},"serviceEndpoints":[{"clickTrackingParams":"CAcQmysiEwjf67-v4tmTAxWJcPUFHX0iMP0yDGl2LWVuZHNjcmVlbsoBBEjJk1w=","commandMetadata":{"webCommandMetadata":{"sendPost":true,"apiUrl":"/youtubei/v1/subscription/subscribe"}},"subscribeEndpoint":{"channelIds":["UCuLl406sTHMqDcn3_sSFEhQ"],"params":"EgIIBBgA"}},{"clickTrackingParams":"CAcQmysiEwjf67-v4tmTAxWJcPUFHX0iMP3KAQRIyZNc","commandMetadata":{"webCommandMetadata":{"sendPost":true}},"signalServiceEndpoint":{"signal":"CLIENT_SIGNAL","actions":[{"clickTrackingParams":"CAcQmysiEwjf67-v4tmTAxWJcPUFHX0iMP3KAQRIyZNc","openPopupAction":{"popup":{"confirmDialogRenderer":{"trackingParams":"CAgQxjgiEwjf67-v4tmTAxWJcPUFHX0iMP0=","dialogMessages":[{"runs":[{"text":"要取消訂閱「"},{"text":"Abigail Rebecca Human Design Business Mentor"},{"text":"」嗎？"}]}],"confirmButton":{"buttonRenderer":{"style":"STYLE_BLUE_TEXT","size":"SIZE_DEFAULT","isDisabled":false,"text":{"runs":[{"text":"取消訂閱"}]},"serviceEndpoint":{"clickTrackingParams":"CAoQ8FsiEwjf67-v4tmTAxWJcPUFHX0iMP0yDGl2LWVuZHNjcmVlbsoBBEjJk1w=","commandMetadata":{"webCommandMetadata":{"sendPost":true,"apiUrl":"/youtubei/v1/subscriptio